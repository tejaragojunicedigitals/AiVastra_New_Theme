<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <RelativeLayout
        android:layout_width="@dimen/_60sdp"
        android:layout_height="wrap_content"
        android:id="@+id/rl_select_face"
        android:layout_marginLeft="@dimen/_5sdp"
        android:layout_marginRight="@dimen/_5sdp"
        android:gravity="center"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/ll_face_photo"
            android:gravity="center"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <ImageView
                    android:layout_width="@dimen/_58sdp"
                    android:layout_height="@dimen/_58sdp"
                    android:layout_gravity="center"
                    android:scaleType="centerCrop"
                    android:clipToOutline="true"
                    android:background="@drawable/bg_cat_item_border_purple"
                    android:backgroundTint="@android:color/transparent"
                    android:src="@drawable/image_model_new"
                    android:id="@+id/ic_category" />

                <View
                    android:id="@+id/selectedBorder"
                    android:layout_width="@dimen/_60sdp"
                    android:layout_height="@dimen/_60sdp"
                    android:background="@drawable/bg_cat_item_border_purple"
                    android:visibility="gone"/>

            </RelativeLayout>


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="saree"
                android:layout_gravity="center"
                android:textColor="@color/black"
                android:fontFamily="@font/popins_medium"
                android:textSize="@dimen/_12sdp"
                android:textAlignment="center"
                android:id="@+id/txt_cat_name"/>

        </LinearLayout>

    </RelativeLayout>

</layout>